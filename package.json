{
  "name": "final-backend-iii",
  "version": "1.0.0",
  "description": "Entregable final: tests funcionales + docker image",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage",
    "seed:users": "node scripts/seed-users.js",
    "docker:build": "docker build -t final-backend-iii:1.0.0 .",
    "docker:run": "docker run --rm -p 3000:3000 --name final-backend-iii final-backend-iii:1.0.0",
    "docker:scan": "docker scout quickview final-backend-iii:1.0.0"
  },
  "keywords": [
    "node",
    "express",
    "jest",
    "docker"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "mongoose": "^8.19.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  }
}
